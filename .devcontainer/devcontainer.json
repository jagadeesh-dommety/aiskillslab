{
    "name": "AI Skills Lab - .NET 8",
  
    "image": "mcr.microsoft.com/devcontainers/dotnet:8.0",
  
    "customizations": {
      "vscode": {
        "extensions": [
          "ms-dotnettools.csharp",
          "GitHub.copilot",
          "GitHub.copilot-chat",
          "ms-azuretools.vscode-docker",
          "pomdtr.excalidraw-editor"
        ]
      }
    },
  
    "postCreateCommand": "dotnet restore",
  
    "remoteUser": "vscode"
  }